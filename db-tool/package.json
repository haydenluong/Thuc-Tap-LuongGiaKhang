{
  "name": "db-tool",
  "version": "1.0.0",
  "description": "CLI Tool – Database Backup / Restore / Verify / Rollback",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
